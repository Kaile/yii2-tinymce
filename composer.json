{
    "name": "moonlandsoft/yii2-tinymce",
    "description": "The TinyMCE Extension for yii framework",
    "type": "yii2-extension",
    "keywords": ["yii2","extension","tinymce","wyswyg","editor","text"],
    "license": "MIT",
    "authors": [
        {
            "name": "Moh Khoirul Anam",
            "email": "moh.khoirul.anaam@gmail.com"
        },
        {
            "name": "Mikhail Kornilov",
            "email": "mikh.kornilov@gmail.com"
        }
    ],
    "require": {
        "yiisoft/yii2": "*",
        "moonlandsoft/helpers": "*",
        "npm-asset/tinymce-i18n": "^22.5",
        "npm-asset/tinymce": "^6.3"
    },
    "autoload": {
        "psr-4": {
            "moonland\\tinymce\\": ""
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    }
}
